# Cloudflare credentials for KV backup/restore scripts
# Copy this file to .env.local and fill in values. .env.local is gitignored.

# Account ID (already known)
CF_ACCOUNT_ID=e3391acd7ec261a0d13d20956a7b3668

# Auth — use EITHER token (preferred) OR email+key
# Option A: scoped API Token with permission "Workers KV Storage:Read" (+ :Write for restore)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# Option B: Global API Key (works but less secure)
# CF_AUTH_EMAIL=
# CF_AUTH_KEY=

# Default target: worker name. Script resolves KV via worker bindings (reliable).
# - tg-challenge-bot       → PROD KV (599c3ef3... title=CHALLENGE_KV)
# - tg-test-challange-bot  → TEST KV (69b8fd57... title=test-challenge)
CF_WORKER=tg-challenge-bot
# Bindings can have multiple KV namespaces — pick by binding variable name in code:
CF_KV_BINDING=CHALLENGE_KV

# Manual overrides (used by both scripts if set, bypass auto-resolution)
# CF_KV_NAMESPACE_ID=
# CF_KV_NAMESPACE_TITLE=
